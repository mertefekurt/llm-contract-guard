{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SupportTicketClassification",
  "type": "object",
  "required": ["category", "priority", "confidence", "needs_human_review"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": ["billing", "bug", "security", "account", "other"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needs_human_review": {
      "type": "boolean"
    }
  }
}
